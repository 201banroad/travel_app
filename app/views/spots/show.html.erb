<div class="spots-show-container">
      <h1 class="spot-title"><%= @spot.title %></h1>
    <div class="paper-main-layout">
      <div class="paper-left-section">
        <% if @spot.images.attached? %>
          <% @spot.images.each do |image| %>
            <img src="<%= url_for(image.variant(format: :jpg)) %>" alt="<%= image_alt_text(image) %>" class="gallery-image" />
          <% end %>
        <% end %>

        <div class="left-info-section">
          <% if user_signed_in? %>
            <div class="like-action">
              <% if current_user.likes.exists?(spot: @spot) %>  
                <%= link_to spot_like_path(@spot), data: { turbo_method: :delete }, class: "like-btn liked" do %>
                  <i class="fa-solid fa-heart"></i>
                <% end %>
              <% else %>
                <%= link_to spot_like_path(@spot), data: { turbo_method: :post }, class: "like-btn" do %>
                  <i class="fa-regular fa-heart"></i>
                <% end %>
              <% end %>
              <span class="like-count"><%= @spot.likes.count %></span>
            </div>
          <% end %>

          <div class="info-group">
            <span class="info-label">Author</span>
            <% if @spot.user.present? %>
              <%= link_to @spot.user.name, user_path(@spot.user), class: "info-value" %>
            <% else %>
              <span class="info-value">ゲスト</span>
            <% end %>
          </div>

          <div class="info-group">
            <span class="info-label">Location</span>
            <%= link_to @spot.location, "https://www.google.com/maps/search/?api=1&query=#{ERB::Util.url_encode(@spot.location)}", target: "_blank", rel: "noopener", class: "info-value" %>
          </div>
        </div>
      </div>

      <div class="paper-content">
        <%= simple_format(@spot.description) %>
      </div>
    </div>

    <footer class="paper-footer">
      <% if user_signed_in? && current_user == @spot.user %>
        <%= link_to '削除', spot_path(@spot), data: { turbo_method: "delete", turbo_confirm: '本当に削除しますか?'}, class: "delete-button" %>
      <% end %>
    </footer>
  </div>

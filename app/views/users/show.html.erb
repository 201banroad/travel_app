<h1><%= @user.name %> さんのこれまでの旅</h1>

<% if @user.avatar.attached? %>
  <%= image_tag url_for(@user.avatar), class: "avatar" %>
<% else %>
  <%= image_tag "default_avatar.png", class: "avatar" %>
<% end %>



<h2><%= @user.name %>さんの投稿した旅</h2>
<% @spots.each do |spot| %>
  <div>
    <%= link_to spot.title, spot_path(spot) %>
  </div>
<% end %>

<% if user_signed_in? %>
  <%= link_to "アカウント編集", edit_user_registration_path %>
<% end %>


<% if user_signed_in? %>
  <%= link_to "アカウント削除", registration_path(current_user),
      data: { 
        turbo_method: :delete,
        turbo_confirm: "本当にアカウントを削除してもよいですか？投稿も全て削除されます"
      },
      class: "danger-button" %>
<% end %>
